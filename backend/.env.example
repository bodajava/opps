NODE_ENV=development
PORT=4001
API_PREFIX=api
APP_NAME=opps
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

MONGODB_URI=mongodb://localhost:27017/opps

JWT_ACCESS_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=30d

VERIFICATION_PROOF_SECRET=replace_with_a_long_random_secret_at_least_32_chars

BCRYPT_SALT_ROUNDS=12

CORS_ORIGINS=http://localhost:3000

COOKIE_SECRET=replace_with_a_long_random_secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=opps
EMAIL_FROM_ADDRESS=noreply@opps.com
SUPPORT_EMAIL=

EMAIL_PROVIDER=smtp
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_RESEND_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5
DEV_EMAIL_OTP_CONSOLE=false

ADMIN_SEED_NAME=opps Admin
ADMIN_SEED_EMAIL=oppsfoods.egy@gmail.com
ADMIN_SEED_PASSWORD=replace_with_a_strong_admin_password
RUN_ADMIN_SEED=false

DEFAULT_CURRENCY=EGP
DEFAULT_COUNTRY=EG
DEFAULT_TIMEZONE=Africa/Cairo

PAYMENT_PROVIDER=disabled
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_WEBHOOK_URL=

FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_WEBHOOK_SECRET=

INSTAPAY_ENABLED=false
INSTAPAY_ACCOUNT_REFERENCE=

VODAFONE_CASH_ENABLED=false
VODAFONE_CASH_NUMBER=

ORANGE_CASH_ENABLED=false
ORANGE_CASH_NUMBER=

ETISALAT_CASH_ENABLED=false
ETISALAT_CASH_NUMBER=

WE_PAY_ENABLED=false
WE_PAY_NUMBER=

CASH_ON_DELIVERY_ENABLED=true
CASH_ON_DELIVERY_MAX_ORDER_VALUE=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

UPLOAD_PROVIDER=local
MAX_UPLOAD_SIZE_MB=5

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Redis (use a newly rotated credential; never commit the real URL)
REDIS_ENABLED=true
REDIS_URL=redis://default:replace_with_rotated_password@your-redis-host:6379
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_KEY_PREFIX=opps
REDIS_RATE_LIMIT_ENABLED=true
EMAIL_QUEUE_ENABLED=true
EMAIL_QUEUE_NAME=opps-email
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_MAX_ATTEMPTS=5
EMAIL_QUEUE_BACKOFF_MS=5000
EMAIL_QUEUE_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key
EMAIL_DEDUPLICATION_TTL_SECONDS=300
OTP_LOCK_SECONDS=900
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCK_SECONDS=900
FORGOT_PASSWORD_MAX_REQUESTS=3
FORGOT_PASSWORD_WINDOW_SECONDS=900
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

LOG_LEVEL=debug
