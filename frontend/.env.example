NEXT_PUBLIC_APP_NAME=opps
NEXT_PUBLIC_APP_URL=https://your-frontend.example.com
# Required in production. Must point to the deployed backend API and must not be localhost.
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api
NEXT_PUBLIC_DEFAULT_CURRENCY=EGP
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_ENABLE_CUSTOMER_ACCOUNTS=true
NEXT_PUBLIC_ENABLE_COD=true
NEXT_PUBLIC_ENABLE_ONLINE_PAYMENT=false
NEXT_PUBLIC_ENABLE_WALLET_PAYMENT=false
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
